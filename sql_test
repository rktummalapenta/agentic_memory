    271 +def compute_pairwise_tests(
    272 +    results: dict[str, list[dict[str, Any]]],
    273 +    labels: dict[str, str],
    274 +    *,
    275 +    bootstrap_samples: int,
    276 +    seed: int,
    277 +) -> list[dict[str, Any]]:
    278 +    rows: list[dict[str, Any]] = []
    279 +    for left, right in combinations(sorted(results.keys()), 2):
    280 +        left_map = {row_key(row): bool(row["is_correct"]) for row in results[left]}
    281 +        right_map = {row_key(row): bool(row["is_correct"]) for row in results[right]}
    282 +        discordant_left = 0
    283 +        discordant_right = 0
    284 +        left_correct = 0
    285 +        right_correct = 0
    286 +        for key in sorted(left_map):
    287 +            lv = left_map[key]
    288 +            rv = right_map[key]
    289 +            if lv:
    290 +                left_correct += 1
    291 +            if rv:
    292 +                right_correct += 1
    293 +            if lv and not rv:
    294 +                discordant_left += 1
    295 +            elif rv and not lv:
    296 +                discordant_right += 1
    297 +        discordant_total = discordant_left + discordant_right
    298 +        p_exact = binom_two_sided_pvalue(min(discordant_left, discordant_right), discordant_total)
    299 +        delta = (left_correct / len(left_map)) - (right_correct / len(right_map))
    300 +        ci_low, ci_high = paired_bootstrap_delta_ci(
    301 +            results[left],
    302 +            results[right],
    303 +            samples=bootstrap_samples,
    304 +            seed=seed,
    305 +        )
    306 +        rows.append(
    307 +            {
    308 +                "left_condition": left,
    309 +                "left_label": labels.get(left, left),
    310 +                "right_condition": right,
    311 +                "right_label": labels.get(right, right),
    312 +                "left_correct_right_wrong": discordant_left,
    313 +                "right_correct_left_wrong": discordant_right,
    314 +                "discordant_total": discordant_total,
    315 +                "delta_accuracy": round(delta, 6),
    316 +                "delta_ci_low": round(ci_low, 6),
    317 +                "delta_ci_high": round(ci_high, 6),
    318 +                "mcnemar_p_exact": round(p_exact, 8),
    319 +            }
    320 +        )
    321 +    adjusted = holm_bonferroni(rows, "mcnemar_p_exact")
    322 +    for row, adj in zip(rows, adjusted):
    323 +        row["holm_adjusted_p"] = round(adj, 8)
    324 +        row["significant_0_05"] = adj < 0.05
    325 +    return rows
