    130 +def percentile(sorted_values: list[float], p: float) -> float:
    131 +    if not sorted_values:
    132 +        return 0.0
    133 +    if len(sorted_values) == 1:
    134 +        return sorted_values[0]
    135 +    pos = (len(sorted_values) - 1) * p
    136 +    low = math.floor(pos)
    137 +    high = math.ceil(pos)
    138 +    if low == high:
    139 +        return sorted_values[low]
    140 +    fraction = pos - low
    141 +    return sorted_values[low] * (1.0 - fraction) + sorted_values[high] * fraction
