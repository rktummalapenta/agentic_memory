    117 +def holm_bonferroni(rows: list[dict[str, Any]], p_key: str) -> list[float]:
    118 +    indexed = sorted(enumerate(rows), key=lambda item: item[1][p_key])
    119 +    adjusted = [1.0] * len(rows)
    120 +    running_max = 0.0
    121 +    m = len(rows)
    122 +    for rank, (idx, row) in enumerate(indexed):
    123 +        factor = m - rank
    124 +        adj = min(1.0, row[p_key] * factor)
    125 +        running_max = max(running_max, adj)
    126 +        adjusted[idx] = running_max
    127 +    return adjusted
