    144 +def paired_bootstrap_delta_ci(
    145 +    left: list[dict[str, Any]],
    146 +    right: list[dict[str, Any]],
    147 +    *,
    148 +    samples: int,
    149 +    seed: int,
    150 +) -> tuple[float, float]:
    151 +    rng = random.Random(seed)
    152 +    left_map = {row_key(row): bool(row["is_correct"]) for row in left}
    153 +    right_map = {row_key(row): bool(row["is_correct"]) for row in right}
    154 +    keys = sorted(left_map)
    155 +    deltas: list[float] = []
    156 +    n = len(keys)
    157 +    for _ in range(samples):
    158 +        sample_keys = [keys[rng.randrange(n)] for _ in range(n)]
    159 +        left_acc = sum(left_map[key] for key in sample_keys) / n
    160 +        right_acc = sum(right_map[key] for key in sample_keys) / n
    161 +        deltas.append(left_acc - right_acc)
    162 +    deltas.sort()
    163 +    return (percentile(deltas, 0.025), percentile(deltas, 0.975))
