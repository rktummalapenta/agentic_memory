    110 +def binom_two_sided_pvalue(k: int, n: int) -> float:
    111 +    if n == 0:
    112 +        return 1.0
    113 +    tail = sum(math.comb(n, i) for i in range(0, k + 1)) / (2**n)
    114 +    return min(1.0, 2.0 * tail)
